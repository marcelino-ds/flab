{
  "manifest_version": 3,
  "name": "Prelab",
  "version": "2.0.0",
  "description": "Auto-solve soal praktikum Gunadarma (iLab) via Gemini.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "tabs",
    "clipboardWrite",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://praktikum.gunadarma.ac.id/*",
    "https://v-class.gunadarma.ac.id/*",
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://praktikum.gunadarma.ac.id/*",
        "https://v-class.gunadarma.ac.id/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["injectors/gemini.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
